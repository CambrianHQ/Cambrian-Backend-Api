# ─── Cambrian Backend — Environment Variables ───────────────────
# Copy to .env and fill in real values.
# Same var names used in local dev, staging, and production.
# ─────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────
# Local: use docker-compose db service or a local Postgres 16
ConnectionStrings__DefaultConnection=***REDACTED***

# ─── JWT ─────────────────────────────────────────────────────────
# Must be >= 32 characters
Jwt__Key=***REDACTED***
Jwt__Issuer=cambrian-api
Jwt__Audience=cambrian-client

# ─── Stripe ──────────────────────────────────────────────────────
# Use sk_test_* keys for local/staging, sk_live_* for production
Stripe__SecretKey=
Stripe__WebhookSecret=

# ─── Storage ─────────────────────────────────────────────────────
# "local" for dev (files in wwwroot/uploads), "s3" or "r2" for prod
Storage__Provider=local
Storage__Endpoint=
Storage__Bucket=cambrian-audio
Storage__AccessKey=
Storage__SecretKey=
Storage__Region=auto
Storage__LocalPath=wwwroot/uploads
Storage__PublicUrl=

# ─── Email ───────────────────────────────────────────────────────
# "console" for dev (logs to stdout), "resend" for prod
Email__Provider=console
Email__FromAddress=noreply@cambrianmusic.com
Email__FromName=Cambrian Music
Email__ResendApiKey=

# ─── App ─────────────────────────────────────────────────────────
App__FrontendUrl=http://localhost:5173
App__CorsOrigins=http://localhost:5173,http://localhost:5174

# ─── Rate Limiting ───────────────────────────────────────────────
RateLimiting__GlobalPermitLimit=500
RateLimiting__AuthPermitLimit=200
