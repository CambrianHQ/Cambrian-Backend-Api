# -- Required in production / staging --
# On Render, set these in the dashboard (sync: false in render.yaml)
# Locally, copy this file to .env and fill in values

# -- ASP.NET Environment (Development | Staging | Production) --
ASPNETCORE_ENVIRONMENT=Staging

# -- Database --
# Render provides DATABASE_URL automatically from the linked database.
# For local/docker: use the ADO.NET format below.
POSTGRES_PASSWORD=cambrian
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=cambrian;Username=cambrian;Password=cambrian

# -- JWT --
# Generate with: openssl rand -base64 48
JWT_KEY=your-production-jwt-secret-min-32-chars

# -- Stripe --
# Staging: use sk_test_... / whsec_... from Stripe test dashboard
# Production: use sk_live_... / whsec_... from Stripe live dashboard
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# -- Object Storage (local | s3 | r2) --
# local: writes to wwwroot/uploads (ephemeral on Render)
# s3/r2: persistent cloud storage
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_BUCKET=cambrian-audio
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# -- Email (console | smtp) --
EMAIL_PROVIDER=console
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# -- App / CORS --
# Staging frontend on Vercel
FRONTEND_URL=https://cambrian-test.vercel.app
CORS_ORIGINS=https://cambrian-test.vercel.app,https://cambrian-staging.vercel.app
# Production values:
# FRONTEND_URL=https://cambrianmusic.com
# CORS_ORIGINS=https://cambrianmusic.com,https://www.cambrianmusic.com