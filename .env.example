# ─── Required in production / staging ────────────────────────────
# On Render, set Jwt__Key in the dashboard (sync: false in render.yaml)
JWT_KEY=your-production-jwt-secret-min-32-chars

# ─── ASP.NET Environment (Development | Staging | Production) ───
ASPNETCORE_ENVIRONMENT=Staging

# ─── Database ────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambrian

# ─── Stripe (required for real payments) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# ─── Object Storage (local | s3 | r2) ───────────────────────────
STORAGE_PROVIDER=local
STORAGE_ENDPOINT=
STORAGE_BUCKET=cambrian-audio
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ─── Email (console | smtp) ─────────────────────────────────────
EMAIL_PROVIDER=console
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=

# ─── App ─────────────────────────────────────────────────────────
# For staging: use the Vercel staging URL
FRONTEND_URL=https://cambrian-staging.vercel.app
CORS_ORIGINS=https://cambrian-staging.vercel.app
