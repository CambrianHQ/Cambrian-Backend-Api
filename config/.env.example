# ============================================================
# Cambrian Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in values.
# On Render, set secrets in the dashboard (sync: false in render.yaml).
# NO REAL SECRETS in this file — placeholders only.
#
# See also: manifests/BACKEND_MANIFEST.json (envVariables section)
# Policy: policy/POLICY.md Section 2 — all env changes must update this file.
# ============================================================

# -- ASP.NET Environment --
# Values: Development | Staging | Production | Testing
ASPNETCORE_ENVIRONMENT=Staging

# -- HTTP Port --
# Render injects PORT automatically. Default 8080 in Docker.
# PORT=8080

# -- Database --
# Render auto-links DATABASE_URL from the linked PostgreSQL instance.
# For local/docker, use the ADO.NET connection string format.
POSTGRES_PASSWORD=cambrian
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# ConnectionStrings__DefaultConnection=***REDACTED***

# -- JWT --
# REQUIRED. Minimum 32 characters.
# Generate with: openssl rand -base64 48
JWT_KEY=your-production-jwt-secret-min-32-chars
# Alternative binding:
# Jwt__Key=your-production-jwt-secret-min-32-chars

# -- Stripe --
# Staging: sk_test_... / whsec_... from Stripe test dashboard
# Production: sk_live_... / whsec_... from Stripe live dashboard
Stripe__SecretKey=sk_test_placeholder
Stripe__WebhookSecret=whsec_placeholder

# -- Object Storage --
# Providers: local | s3 | r2
# local: writes to wwwroot/uploads (ephemeral on Render — NOT for production)
# s3/r2: persistent cloud storage (REQUIRED in production)
Storage__Provider=local
Storage__Endpoint=
Storage__Bucket=cambrian-audio
Storage__AccessKey=
Storage__SecretKey=
Storage__Region=auto
Storage__PublicUrl=
# Storage__UsePathStyle=true  (required for R2)
# Storage__LocalPath=wwwroot/uploads  (local provider only)

# -- Email --
# Providers: console | smtp | resend | sendgrid
# console: logs to stdout (NOT for production)
# smtp/resend: real email delivery (REQUIRED in production)
# Resend quick start:
#   Email__Provider=resend
#   Email__FromAddress=hello@yourdomain.com
#   Email__FromName=Cambrian Music
#   Email__ResendApiKey=re_xxxxxxxxx
#   Resend webhook target: POST https://<your-api-host>/webhook/email
Email__Provider=console
Email__FromAddress=noreply@cambrianmusic.com
Email__FromName=Cambrian Music
Email__SmtpHost=
Email__SmtpPort=587
Email__SmtpUser=
Email__SmtpPass=
Email__ResendApiKey=
# Email__SendGridApiKey=

# -- App / CORS --
# REQUIRED. Frontend base URL for redirects and CORS.
FRONTEND_URL=https://cambrian-test.vercel.app
CORS_ORIGINS=https://cambrian-test.vercel.app,https://cambrian-staging.vercel.app
# Production values:
# FRONTEND_URL=https://cambrianmusic.com
# CORS_ORIGINS=https://cambrianmusic.com,https://www.cambrianmusic.com

# -- Admin Seed Account --
# Used to create the initial admin user on first startup.
Admin__Email=
Admin__Password=
