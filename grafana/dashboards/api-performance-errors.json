{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Cambrian — API Performance & Errors",
  "uid": "cambrian-api-perf",
  "description": "Endpoint-centric latency, throughput, and error analysis.",
  "tags": ["cambrian", "performance", "errors"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "query": "label_values(http_server_request_duration_seconds_count{job=\"cambrian-api\"}, route)",
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "heatmap",
      "title": "Latency Heatmap by Route",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (le) (increase(http_server_request_duration_seconds_bucket{job=\"cambrian-api\",route=~\"$route\"}[5m]))",
          "format": "heatmap",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "type": "table",
      "title": "Top 10 Slowest Routes (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(http_server_request_duration_seconds_bucket{job=\"cambrian-api\"}[5m]))))",
          "format": "table",
          "instant": true,
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "renameByName": { "Value": "p95 (s)", "route": "Route" } } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests / sec by Route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum by (route, method) (rate(http_server_request_duration_seconds_count{job=\"cambrian-api\",route=~\"$route\"}[5m]))",
          "legendFormat": "{{method}} {{route}}",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "4xx by Route",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_server_request_duration_seconds_count{job=\"cambrian-api\",status_code=~\"4..\",route=~\"$route\"}[5m]))",
          "legendFormat": "{{route}}",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx by Route",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_server_request_duration_seconds_count{job=\"cambrian-api\",status_code=~\"5..\",route=~\"$route\"}[5m]))",
          "legendFormat": "{{route}}",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbound Dependency Latency",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_seconds_bucket{job=\"cambrian-api\",server_address=~\".*stripe.*\"}[5m])))",
          "legendFormat": "Stripe p95",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_client_request_duration_seconds_bucket{job=\"cambrian-api\",server_address=~\".*supabase.*|.*s3.*|.*r2.*\"}[5m])))",
          "legendFormat": "Storage p95",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB Query Duration (EF Core)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(db_client_operation_duration_seconds_bucket{job=\"cambrian-api\"}[5m])))",
          "legendFormat": "DB p95",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(db_client_operation_duration_seconds_bucket{job=\"cambrian-api\"}[5m])))",
          "legendFormat": "DB p50",
          "datasource": { "uid": "${DS_PROMETHEUS}" }
        }
      ]
    }
  ]
}
