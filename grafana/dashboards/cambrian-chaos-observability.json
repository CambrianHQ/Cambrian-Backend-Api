{
  "title": "Cambrian - Chaos Experiment Observability",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "API Latency During Chaos",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, experiment) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Database Errors",
      "targets": [
        {
          "expr": "sum(rate(cambrian_database_errors_total[5m]))",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Stripe Dependency Failures",
      "targets": [
        {
          "expr": "sum(rate(cambrian_stripe_errors_total[5m]))",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Storage Failures",
      "targets": [
        {
          "expr": "sum(rate(cambrian_storage_errors_total[5m]))",
          "refId": "D"
        }
      ]
    }
  ]
}
