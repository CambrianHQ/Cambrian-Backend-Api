{
  "title": "Cambrian - Executive System Health",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "API Availability (%)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "avg(up{job=\"cambrian-api\"}) * 100",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latency (ms)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m]))) * 1000",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests per Second",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count[1m]))",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{status_code=~\"5..\"}[5m]))",
          "refId": "D"
        }
      ]
    }
  ]
}
