{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Cambrian — Executive System Health",
  "uid": "cambrian-exec-health",
  "description": "High-level operational view: availability, latency, error rates, resource usage.",
  "tags": ["cambrian", "health", "executive"],
  "timezone": "browser",
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "API Availability",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 95 },
              { "color": "green", "value": 99.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(up{job=\"cambrian-api\"}) * 100",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"cambrian-api\"}[5m])))",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "stat",
      "title": "5xx Error Rate",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"cambrian-api\",http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"cambrian-api\"}[5m]))",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Checkout Success Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cambrian_checkout_completed_total[5m])) / clamp_min(sum(rate(cambrian_checkout_started_total[5m])), 1)",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Upload Success Rate",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cambrian_upload_completed_total[5m])) / clamp_min(sum(rate(cambrian_upload_completed_total[5m]) + rate(cambrian_upload_failed_total[5m])), 1)",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "stat",
      "title": "Webhook Success Rate",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(cambrian_webhook_failed_total[5m])) / clamp_min(sum(rate(cambrian_webhook_processed_total[5m])), 1))",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"cambrian-api\"}[1m]))",
          "legendFormat": "total",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"cambrian-api\"}[5m])))",
          "legendFormat": "p50",
          "datasource": { "uid": "cambrian-prometheus" }
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"cambrian-api\"}[5m])))",
          "legendFormat": "p95",
          "datasource": { "uid": "cambrian-prometheus" }
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"cambrian-api\"}[5m])))",
          "legendFormat": "p99",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx Error Rate over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"cambrian-api\",http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count{job=\"cambrian-api\"}[5m]))",
          "legendFormat": "5xx %",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU & Memory",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"cambrian-api\"}[5m])",
          "legendFormat": "CPU (cores)",
          "datasource": { "uid": "cambrian-prometheus" }
        },
        {
          "expr": "process_resident_memory_bytes{job=\"cambrian-api\"} / 1024 / 1024",
          "legendFormat": "RSS (MB)",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Health Endpoint Status",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "up{job=\"cambrian-api\"}",
          "legendFormat": "{{instance}}",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Rate Limiting Rejections",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(aspnetcore_rate_limiting_requests_total{result=\"rejected\",job=\"cambrian-api\"}[5m]))",
          "legendFormat": "429 / sec",
          "datasource": { "uid": "cambrian-prometheus" }
        }
      ]
    }
  ]
}
