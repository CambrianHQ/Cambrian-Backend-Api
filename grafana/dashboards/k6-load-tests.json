{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "k6 load-test metrics (experimental-prometheus-rw output)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "Active VUs",
          "refId": "A"
        }
      ],
      "title": "Virtual Users",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[1m])",
          "legendFormat": "Req/s",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(k6_http_req_duration_milliseconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, rate(k6_http_req_duration_milliseconds_bucket[1m]))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(k6_http_req_duration_milliseconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, rate(k6_http_req_duration_milliseconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "D"
        }
      ],
      "title": "Request Duration Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total[1m]) / rate(k6_http_reqs_total[1m])",
          "legendFormat": "Error rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Request Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (url, le) (rate(k6_http_req_duration_milliseconds_bucket[1m])))",
          "legendFormat": "p95 {{ url }}",
          "refId": "A"
        }
      ],
      "title": "p95 Latency by URL",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (url, status) (rate(k6_http_reqs_total[1m]))",
          "legendFormat": "{{ url }} {{ status }}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by URL + Status",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "Network",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 7,
      "targets": [
        {
          "expr": "rate(k6_data_sent_bytes_total[1m])",
          "legendFormat": "Sent",
          "refId": "A"
        },
        {
          "expr": "rate(k6_data_received_bytes_total[1m])",
          "legendFormat": "Received",
          "refId": "B"
        }
      ],
      "title": "Network Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "cambrian-prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 8,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(k6_http_req_connecting_milliseconds_bucket[1m]))",
          "legendFormat": "Connecting p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(k6_http_req_waiting_milliseconds_bucket[1m]))",
          "legendFormat": "Waiting (TTFB) p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, rate(k6_http_req_receiving_milliseconds_bucket[1m]))",
          "legendFormat": "Receiving p95",
          "refId": "C"
        }
      ],
      "title": "Request Phase Breakdown (p95)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["k6", "load-testing", "cambrian"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "k6 Load Tests",
  "uid": "cambrian-k6-loadtest",
  "version": 1
}
