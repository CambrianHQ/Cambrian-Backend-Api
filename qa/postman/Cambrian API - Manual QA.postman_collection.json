            }
          }
        }
      ]
    },
    {
      "name": "Payouts",
      "item": [
        {
          "name": "Get Payout History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{creatorToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/payouts/history",
              "host": ["{{baseUrl}}"],
              "path": ["payouts", "history"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users"]
            }
          }
        }
      ]
    },
    {
      "name": "Webhooks (Simulation)",
      "item": [
        {
          "name": "Stripe Webhook Simulation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Stripe-Signature", "value": "t=1234567890,v1=replace-me-for-live-signature-tests" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_manual_qa\",\n  \"type\": \"checkout.session.completed\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"cs_manual_qa\",\n      \"client_reference_id\": \"buyer-id:{{trackId}}:non-exclusive\",\n      \"amount_total\": 2999\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/webhook/stripe",
              "host": ["{{baseUrl}}"],
              "path": ["webhook", "stripe"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "creatorSlug",
      "value": "echopulse"
    }
  ]
}
