{
  "info": {
    "name": "Cambrian API - Manual QA",
    "_postman_id": "a7f18eb2-17bd-4fd5-a718-cambrian-manual-qa",
    "description": "Starter manual QA collection for the Cambrian backend API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login successful\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.environment.set(\"authToken\", json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"creator@cambrian.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Catalog",
      "item": [
        {
          "name": "Get Catalog",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Catalog retrieved\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.expect(json.success).to.eql(true);",
                  "pm.expect(json.data.length).to.be.greaterThan(0);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/catalog",
              "host": ["{{baseUrl}}"],
              "path": ["catalog"]
            }
          }
        },
        {
          "name": "Discover Tracks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/discover?genre=ambient",
              "host": ["{{baseUrl}}"],
              "path": ["discover"],
              "query": [
                { "key": "genre", "value": "ambient" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Tracks",
      "item": [
        {
          "name": "Get Track By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tracks/{{trackId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tracks", "{{trackId}}"]
            }
          }
        },
        {
          "name": "Trending",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/trending",
              "host": ["{{baseUrl}}"],
              "path": ["trending"]
            }
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Track",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{creatorToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "audio", "type": "file", "src": "sample.mp3" },
                { "key": "title", "type": "text", "value": "Ambient Dreams" },
                { "key": "genre", "type": "text", "value": "Ambient" },
                { "key": "nonExclusivePrice", "type": "text", "value": "29" },
                { "key": "exclusivePrice", "type": "text", "value": "499" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/upload",
              "host": ["{{baseUrl}}"],
              "path": ["upload"]
            }
          }
        }
      ]
    },
    {
      "name": "Checkout & Purchases",
      "item": [
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackId\": \"{{trackId}}\",\n  \"licenseType\": \"non-exclusive\",\n  \"usageType\": \"personal\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["checkout"]
            }
          }
        },
        {
          "name": "Create Purchase Record",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trackId\": \"{{trackId}}\",\n  \"licenseType\": \"non-exclusive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/purchases",
              "host": ["{{baseUrl}}"],
              "path": ["purchases"]
            }
          }
        }
      ]
    },
    {
      "name": "Library",
      "item": [
        {
          "name": "Get Library",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/library",
              "host": ["{{baseUrl}}"],
              "path": ["library"]
