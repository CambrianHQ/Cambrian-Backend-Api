              "raw": "{{baseUrl}}/creator/username/{{creatorSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["creator", "username", "{{creatorSlug}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Subscriptions",
      "item": [
        {
          "name": "Get Plans",
          "request": {
