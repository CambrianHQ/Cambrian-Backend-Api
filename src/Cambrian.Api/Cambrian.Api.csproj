    <PackageReference Include="QuestPDF" Version="2026.2.3" />
    <PackageReference Include="Sentry.AspNetCore" Version="6.6.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Cambrian.Application\Cambrian.Application.csproj" />
    <ProjectReference Include="..\Cambrian.Persistence\Cambrian.Persistence.csproj" />
    <ProjectReference Include="..\Cambrian.Infrastructure\Cambrian.Infrastructure.csproj" />
  </ItemGroup>

  <!-- Generated stubs are reference only — excluded from compilation -->
  <ItemGroup>
    <Compile Remove="GeneratedControllers\**" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Cambrian.Api.Tests" />
  </ItemGroup>

</Project>
