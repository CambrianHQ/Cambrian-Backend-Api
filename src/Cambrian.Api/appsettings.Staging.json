{
  "Jwt": {
    "Issuer": "cambrian-api",
    "Audience": "cambrian-client"
  },
  "Storage": {
    "Provider": "local",
    "LocalPath": "wwwroot/uploads"
  },
  "Email": {
    "Provider": "console"
  },
  "RateLimiting": {
    "GlobalPermitLimit": 500,
    "AuthPermitLimit": 100
  },
  "App": {
    "FrontendUrl": "https://cambrian-test.vercel.app",
    "CorsOrigins": "https://cambrian-test.vercel.app,https://cambrian-staging.vercel.app",
    "VercelProjectSlug": "cambrian-test"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}